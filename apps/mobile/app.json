{
  "expo": {
    "name": "Xenios",
    "slug": "xenios",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "xenios",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xenios.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.xenios.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "722bdc63-6ebe-4fa1-abc3-69440309290d"
      }
    },
    "owner": "xenios-mvp"
  }
}
